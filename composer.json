{
  "name": "mantejs/seo-audit-plugin",
  "description": "Comprehensive SEO Audit Plugin for WordPress with AI Integration",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4",
    "davechild/textstatistics": "^1.0",
    "symfony/dom-crawler": "^6.0",
    "symfony/css-selector": "^6.0",
    "voku/simple_html_dom": "^4.8",
    "guzzlehttp/guzzle": "^7.5",
    "openai-php/client": "^0.8",
    "google/apiclient": "^2.15",
    "microsoft/microsoft-graph": "^1.109"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "SEOAudit\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SEOAudit\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpcs": "phpcs --standard=WordPress includes/",
    "phpstan": "phpstan analyse includes/"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
